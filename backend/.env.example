PORT=5000
MONGO_URI=mongodb://localhost:27017/pos-cafe
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=development

# ── Twilio SMS (OTP delivery) ─────────────────────────────────────────────────
# Get these from https://console.twilio.com → Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# A Twilio phone number you purchased (include +country code, e.g. +1XXXXXXXXXX)
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# NOTE: OTP is sent via SMS only when NODE_ENV=production AND all 3 keys above are set.
# In development mode the OTP is printed to the server console instead.
